generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum JobType {
  PPT_GENERATION
  TEMPLATE_EXTRACTION
  REFERENCE_PROCESSING
  STYLE_PROFILE_ANALYSIS
}

enum JobStatus {
  PENDING
  PROCESSING
  AWAITING_REVIEW
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  role         UserRole  @default(USER)
  // Coupon — when redeemed, user bypasses free-tier limits and uses the
  // server's default Gemini key. Stored uppercase.
  couponCode       String?
  couponRedeemedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  oauthAccounts      OAuthAccount[]
  projects           Project[]
  templates          Template[]
  jobs               Job[]
  llmConfigs         LLMConfig[]
  styleProfiles      StyleProfile[]
  knowledgeGraphNodes KnowledgeGraphNode[]
  providerKeys       ProviderApiKey[]
  usageRecords       UsageRecord[]
  sourceFiles        SourceFile[]
  downloadEvents     DownloadEvent[]
  userUploads        UserUpload[]
  apiKeys            ApiKey[]
  supportTickets     SupportTicket[]

  @@map("users")
}

// User-filed support / issue reports. Form is structured (dropdowns) so admin
// triage can filter by category/severity/area; description is the single
// free-text field. The admin dashboard renders these as cards.
model SupportTicket {
  id          String   @id @default(cuid())
  // Human-readable ITSM-style ticket number — "SUP-NNNNNN", monotonically
  // increasing via a Postgres sequence. Surfaced to the user + admin so
  // they can quote it ("I'm stuck on SUP-000042") instead of a 24-char cuid.
  ticketNumber String  @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dropdowns — values are enforced by the API zod schema, not by Postgres
  // enums (so adding a new option doesn't require a migration).
  category    String   // bug | feature_request | ui_issue | performance | billing | account | other
  severity    String   // low | medium | high | critical
  area        String   // generation | editing | preview | dashboard | api | account | other

  // Single free-text field (max 4000 chars).
  description String

  // Optional structured pointers that help admin debug. Captured by the
  // client at submit time — not the user's responsibility.
  projectId   String?
  url         String?
  userAgent   String?

  // Triage state — admin updates via PATCH.
  status      String   @default("open")    // open | in_progress | resolved | closed
  adminNotes  String?
  resolvedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status, createdAt])
  @@map("support_tickets")
}

// Audit log for every inbound v1 API request. Written fire-and-forget so it
// never blocks a response. Drives the admin analytics dashboard. Indexed
// for the common query shapes: per-user / per-key / per-endpoint / time range.
model ApiRequestLog {
  id            String   @id @default(cuid())
  apiKeyId      String?
  userId        String?
  method        String                          // GET, POST, etc.
  endpoint      String                          // e.g. "/v1/decks"
  statusCode    Int
  latencyMs     Int
  jobId         String?                         // populated on deck-create / edit
  errorCode     String?                         // structured error code if any
  ip            String?
  userAgent     String?
  requestSize   Int?                            // bytes
  responseSize  Int?                            // bytes
  createdAt     DateTime @default(now())

  @@index([apiKeyId, createdAt])
  @@index([userId, createdAt])
  @@index([endpoint, createdAt])
  @@index([statusCode])
  @@index([createdAt])
  @@map("api_request_log")
}

// Developer-facing API keys (separate from `provider_api_keys`, which holds
// 3rd-party LLM keys the user pastes in). These are keys we MINT for the
// user so they can call our public REST API + MCP server. Stored encrypted
// at rest so we can show the full value back to the user on demand
// (developer-key UX expectation: copy/paste into your config).
model ApiKey {
  id            String    @id @default(cuid())
  userId        String
  name          String                          // human label, e.g. "Local MCP server"
  prefix        String                          // first 12 chars of the key for safe display
  encryptedKey  String                          // AES-encrypted full key (decryptable)
  // Last 4 chars stored in cleartext for display purposes ("•••• abcd").
  // Helps the user identify a key without revealing the rest.
  last4         String
  expiresAt     DateTime?                       // null = never expires
  lastUsedAt    DateTime?
  revokedAt     DateTime?                       // soft-delete; rejected at auth
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prefix])
  @@map("api_keys")
}

// ─── User Uploads (Files library) ───
// One row per direct upload from the /uploads page (purpose: "general"). The
// existing Template/ReferenceFile/SourceFile/StyleProfileSource tables already
// track their own uploads — the Uploads page UNIONs across all of them and
// surfaces this table for files that don't belong to any of those flows
// (notably paste-as-image and direct user uploads).
model UserUpload {
  id        String   @id @default(cuid())
  userId    String
  s3Key     String   @unique
  fileName  String
  fileSize  Int
  mimeType  String
  purpose   String   // general | chat-image | (future)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_uploads")
}

// ─── Page Views (admin analytics — traffic, geo, devices) ───
// One row per route change. Country is the 2-letter ISO from CF-IPCountry.
// Raw IPs are intentionally NOT stored (privacy + GDPR-friendly).

model PageView {
  id         String   @id @default(cuid())
  userId     String?  // null for unauthenticated
  path       String
  referrer   String?
  country    String?  // ISO 3166-1 alpha-2 (e.g. "IN", "US")
  device     String?  // mobile | tablet | desktop | bot
  uaSummary  String?  // short browser/os tag, never raw UA
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([country, createdAt])
  @@index([path, createdAt])
  @@map("page_views")
}

// ─── Download Events (admin analytics) ───
// One row per PPTX download (presigned URL fetch via /api/presentations/[id]/download).

model DownloadEvent {
  id             String   @id @default(cuid())
  userId         String
  presentationId String?
  projectId      String?
  fileName       String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("download_events")
}

// ─── Find: Source Files ───
// Uploaded PPTX files indexed for slide-level search.
// Each file is broken into slides and stored in slide_index (pgvector, raw SQL).

model SourceFile {
  id          String   @id @default(cuid())
  userId      String
  fileName    String
  s3Key       String
  fileSize    Int
  slideCount  Int?
  status      String   @default("pending") // pending, indexing, ready, failed
  error       String?
  createdAt   DateTime @default(now())
  indexedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("source_files")
}

// ─── Provider API Keys ───
// Stores per-user API keys for each LLM provider.
// When a user has a key for a provider, only that provider's models are shown.
// Keys are encrypted with AES-256-GCM before storing.

model ProviderApiKey {
  id          String   @id @default(cuid())
  userId      String
  provider    String   // google, anthropic, openai, mistral
  apiKeyEnc   String   // Encrypted API key
  isValid     Boolean  @default(false) // Set after validation request
  lastValidated DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("provider_api_keys")
}

// ─── Usage Tracking ───
// Tracks token usage and cost per user per generation.
// Free tier: 1 PPT per 8 hours using server Gemini key.
// Users with their own keys: unlimited, but usage is tracked.

model UsageRecord {
  id              String   @id @default(cuid())
  userId          String
  jobId           String?
  provider        String   // google, anthropic, openai, etc.
  model           String   // gemini-2.5-pro, claude-sonnet-4, etc.
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  totalTokens     Int      @default(0)
  estimatedCostUsd Float   @default(0)
  source          String   @default("user_key") // "user_key" | "free_tier"
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, source])
  @@map("usage_records")
}

// Free tier session tracking — resets every 8 hours.
// `maxGenerations` defaults to 6: enough for users to actually try the
// product without having to add their own API key, but capped so we
// aren't bankrolling unlimited runs on borrowed Gemini keys.
model FreeTierSession {
  id              String   @id @default(cuid())
  userId          String   @unique
  generationsUsed Int      @default(0)
  maxGenerations  Int      @default(6)
  windowStart     DateTime @default(now())
  windowHours     Int      @default(8)
  updatedAt       DateTime @updatedAt

  @@map("free_tier_sessions")
}

model OAuthAccount {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  providerAccountId String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model Project {
  id             String   @id @default(cuid())
  name           String
  prompt         String
  numSlides      Int      @default(10)
  audienceType   String   @default("general")
  userId         String
  templateId     String?
  llmConfigId    String?
  styleProfileId String?
  // Where the project came from: "ui" (default — created in the dashboard),
  // "api" (v1 REST endpoint), or "mcp" (MCP server tool call). API + MCP
  // projects are hidden from the regular dashboard and surfaced on the
  // dedicated /api-usage page instead.
  source         String   @default("ui")
  // The API key that minted this project, when source != "ui". NULL for
  // UI-created projects. Lets us show "which key generated which deck" in
  // the API usage dashboard.
  apiKeyId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template       Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  llmConfig      LLMConfig?     @relation(fields: [llmConfigId], references: [id], onDelete: SetNull)
  styleProfile   StyleProfile?  @relation(fields: [styleProfileId], references: [id], onDelete: SetNull)
  referenceFiles ReferenceFile[]
  presentations  Presentation[]
  jobs           Job[]
  chatMessages   ChatMessage[]
  memory         ProjectMemory?

  @@index([userId])
  @@index([userId, source, createdAt])
  @@index([apiKeyId, createdAt])
  @@map("projects")
}

// Per-project knowledge graph. 1-to-1 with Project. Accumulates everything
// the agent has learned about the project: extracted entities, design
// decisions, prior outlines, surgical edits, user preferences, plus a rolling
// LLM-summarized narrative. Read by every engine; written by the worker
// after each successful generation/edit.
model ProjectMemory {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Extracted nouns/products/tools/people. Array of { label, kind, mentions }.
  entities    Json     @default("[]")

  // Logged design/scope decisions. Array of { what, why, at }.
  decisions   Json     @default("[]")

  // Prior outlines from successful jobs. Array of { jobId, generatedAt, slides: [{ title, summary }] }.
  outlines    Json     @default("[]")

  // Surgical edits log. Array of { instruction, targetSlides, at }.
  edits       Json     @default("[]")

  // User preferences inferred from chat / settings: { engine, creativeMode, audience, ... }.
  preferences Json     @default("{}")

  // LLM-rolled prose summary the agent prompt prepends. Capped ~2000 chars.
  // Rebuilt periodically from the structured fields above.
  narrative   String   @default("")

  // Monotonic counter incremented on every write. Used to decide when to
  // re-summarize narrative (e.g. every 5 writes).
  version     Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("project_memory")
}

model Template {
  id               String   @id @default(cuid())
  name             String
  s3Key            String
  thumbnailUrl     String?
  themeConfig      Json?
  extractionStatus String   @default("pending")
  userId           String
  isPublic         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([userId])
  @@map("templates")
}

model ReferenceFile {
  id               String   @id @default(cuid())
  projectId        String
  fileName         String
  fileType         String
  s3Key            String
  fileSize         Int
  extractedText    String?
  extractionStatus String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("reference_files")
}

model Presentation {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  s3Key         String
  thumbnails    Json?
  slideCount    Int
  version       Int      @default(1)
  metadata      Json?
  // Per-slide pptxgenjs source so we can edit slides surgically
  // without re-running the research → outline → slide_writer pipeline.
  // Shape: [{ slide_number, title, code, speaker_notes }, ...]
  slidesData    Json?
  // The locked palette + style profile snapshot used to render this version.
  // Lets the edit agent reconstruct the brand context without re-querying.
  themeSnapshot Json?
  canvaDesignId String?
  jobId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job     Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("presentations")
}

model Job {
  id                 String    @id @default(cuid())
  bullmqJobId        String?
  type               JobType
  status             JobStatus @default(PENDING)
  progress           Float     @default(0)
  currentPhase       String?
  projectId          String
  userId             String
  input              Json?
  output             Json?
  error              String?
  attempts           Int       @default(0)
  langGraphThreadId  String?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  presentations Presentation[]

  @@index([projectId])
  @@index([userId])
  @@index([bullmqJobId])
  @@map("jobs")
}

model LLMConfig {
  id          String   @id @default(cuid())
  name        String
  provider    String
  model       String
  baseUrl     String?
  apiKeyEnc   String?
  temperature Float    @default(0.7)
  maxTokens   Int      @default(4096)
  isDefault   Boolean  @default(false)
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([userId])
  @@map("llm_configs")
}

model StyleProfile {
  id                String   @id @default(cuid())
  name              String
  description       String?
  userId            String?  // null for global/default profiles offered to every user
  isGlobal          Boolean  @default(false) // true for app-level defaults (IBM, ICICI, Wipro)
  // Catalog category — IT, BFSI, Education, etc. Drives the filter chips on
  // /catalog and helps users discover styles relevant to their use case.
  category          String?  // it | bfsi | education | consulting | healthcare | retail | manufacturing | nonprofit | other
  // When `isPublic` is true, this profile shows up on /catalog for ALL
  // users to discover + clone. Independent of isGlobal: global = shipped
  // by us; public = user-shared. Both surfaces in the catalog.
  isPublic          Boolean  @default(false)
  // If this profile was cloned from a catalog entry, this points at the
  // original — lets us show "based on BITS Pilani" badges + count clones
  // for analytics.
  clonedFromId      String?
  status            String   @default("pending") // pending, analyzing, ready, failed

  // Structured theme data (merged from all source files)
  themeConfig       Json?    // ThemeConfig: colors, fonts, layouts
  // Visual style analysis from multimodal LLM
  visualStyle       Json?    // VisualStyleAnalysis: design_language, spacing, hierarchy, etc.
  // Natural language style guide generated by LLM
  styleGuide        String?  // Prose description: "This brand uses a clean corporate style..."
  // Aggregated layout patterns found across source files
  layoutPatterns    Json?    // [{type, frequency, description, content_density}]
  // Sample slide thumbnails kept for reference
  sampleThumbnails  Json?    // [s3_key, ...]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceFiles       StyleProfileSource[]
  projects          Project[]
  clonedFrom        StyleProfile?      @relation("StyleClone", fields: [clonedFromId], references: [id], onDelete: SetNull)
  clones            StyleProfile[]     @relation("StyleClone")

  @@index([userId])
  @@index([isGlobal])
  @@index([isPublic, category, status])
  @@map("style_profiles")
}

model StyleProfileSource {
  id              String   @id @default(cuid())
  styleProfileId  String
  fileName        String
  s3Key           String
  fileSize        Int
  slideCount      Int      @default(0)
  sampledSlides   Json?    // [slide_numbers] that were analyzed
  extractedTheme  Json?    // Per-file ThemeConfig before merging
  status          String   @default("pending") // pending, processing, done, failed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  styleProfile    StyleProfile @relation(fields: [styleProfileId], references: [id], onDelete: Cascade)

  @@index([styleProfileId])
  @@map("style_profile_sources")
}

// ─── Knowledge Graph ───
// Per-user graph that accumulates design knowledge from every uploaded file.
// Nodes represent design concepts (color palettes, fonts, layout patterns, etc.)
// Edges represent relationships (palette -> used_in -> layout, font -> pairs_with -> font)

model KnowledgeGraphNode {
  id          String   @id @default(cuid())
  userId      String
  category    String   // palette, font, layout, spacing, visual_element, content_pattern, brand_trait
  label       String   // "Dark corporate palette", "Montserrat + Open Sans", "2-column with icon grid"
  properties  Json     // Category-specific structured data
  confidence  Float    @default(1.0) // 0-1, increases with more source files confirming this pattern
  sourceCount Int      @default(1)   // How many files contributed to this node
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  outEdges    KnowledgeGraphEdge[] @relation("EdgeFrom")
  inEdges     KnowledgeGraphEdge[] @relation("EdgeTo")

  @@unique([userId, category, label])
  @@index([userId, category])
  @@map("knowledge_graph_nodes")
}

model KnowledgeGraphEdge {
  id          String   @id @default(cuid())
  fromNodeId  String
  toNodeId    String
  relation    String   // pairs_with, used_in, contrasts_with, follows, contains
  weight      Float    @default(1.0) // strength of relationship
  properties  Json?
  createdAt   DateTime @default(now())

  fromNode    KnowledgeGraphNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode      KnowledgeGraphNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId, relation])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("knowledge_graph_edges")
}

// ─── Chat Messages ───
// Persistent conversation history per project. Each message is either from
// the user or the assistant (system events like generation progress, outline
// review, errors, etc.). Tied to a project, ordered by createdAt.

model ChatMessage {
  id          String   @id @default(cuid())
  projectId   String
  role        String   // "user" | "assistant" | "system"
  content     String   // The message text (markdown supported)
  metadata    Json?    // Optional structured data: { jobId, phase, outline, slides, error, ... }
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("chat_messages")
}

// ─── Agent Memory ───
// Stores per-job step results so the pipeline can resume from the last successful step.

model AgentMemory {
  id          String   @id @default(cuid())
  jobId       String
  stepName    String   // extract_template, process_references, query_generator, etc.
  stepIndex   Int
  status      String   @default("completed") // completed, failed
  input       Json?
  output      Json?    // The state delta this step produced
  error       String?
  durationMs  Int?
  createdAt   DateTime @default(now())

  @@unique([jobId, stepName])
  @@index([jobId])
  @@map("agent_memory")
}
